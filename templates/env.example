# Dynathi Networkbuild environment template
# Copy this file to .env locally and fill in real values.
# Never commit your real .env file.

PROJECT_NAME=dynathi-networkbuild
ENVIRONMENT=development

# Public-safe placeholder IPs from RFC 5737 documentation ranges
PUBLIC_GATEWAY_IP=203.0.113.10
HOME_NODE_IP=198.51.100.10
GERMANY_NODE_IP=198.51.100.20
BELGIUM_NODE_IP=198.51.100.30

# Domains
ROOT_DOMAIN=example.com
STATUS_DOMAIN=status.example.com
PANEL_DOMAIN=panel.example.com

# Database placeholders
DB_HOST=db
DB_NAME=dynathi
DB_USER=dynathi_user
DB_PASSWORD=CHANGE_ME

# Monitoring
UPTIME_KUMA_ADMIN_EMAIL=admin@example.com
DISCORD_WEBHOOK_URL=CHANGE_ME

# Minecraft/RCON placeholders
MINECRAFT_HOST=CHANGE_ME
MINECRAFT_RCON_PORT=25575
MINECRAFT_RCON_PASSWORD=CHANGE_ME

# WireGuard placeholders
WG_SERVER_PUBLIC_KEY=CHANGE_ME
WG_CLIENT_PUBLIC_KEY=CHANGE_ME
WG_ENDPOINT=CHANGE_ME:51820
