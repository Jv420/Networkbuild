# Copy this file to .env locally.
# Never commit real .env files.

APP_NAME=Dynathi Networkbuild
NODE_ENV=development
LIVE_MODE=false
PORT=3000

# Public-safe placeholders only
PUBLIC_BASE_URL=http://localhost:3000
ADMIN_CONTACT=admin@example.com

# Agent auth. Use the same long random token in the control panel and every trusted agent.
# For LIVE_MODE=true this must be at least 24 characters and not CHANGE_ME.
AGENT_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN

# Optional webhook for status alerts. Keep real value in local .env only.
DISCORD_WEBHOOK_URL=CHANGE_ME

# Compute demo settings
COMPUTE_DEMO_ENABLED=true
COMPUTE_MAX_THREADS=1
COMPUTE_DEFAULT_SECONDS=15
